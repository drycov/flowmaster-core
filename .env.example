# Минимальный набор для запуска ЕСЭДО.
# Все остальные параметры (почта, LDAP, ONLYOFFICE, Telegram, S3) — в UI:
# Администрирование → Настройки системы

# ── Docker (рекомендуется) ────────────────────────────────────────────────────
# Локально:  npm run env:local && npm run docker:up
# Production: npm run env:production -- --domain=esedo.example.kz --install
#             npm run compose:tls:cron
# Шаблон: .env.docker.example | npm run env:local | env:production | env:staging
# Документация: docs/README.md, docs/ARCHITECTURE.md, docs/DEPLOYMENT.md

# ── Supabase (обязательно) ──────────────────────────────────────────────────
# Docker: VITE_SUPABASE_URL=http://localhost:54321
# Сервер на хосте (npm run dev): SUPABASE_URL=http://localhost:54321
# В Docker-контейнере app URL переопределяется на http://kong:8000
SUPABASE_URL=http://localhost:54321
SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Серверные секреты (только на backend, не в браузере)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
# или APP_SESSION_SECRET=your-session-secret

# Опционально: идентификатор инсталляции (иначе вычисляется автоматически)
# INSTALLATION_ID=

# Опционально: подпись лицензий (иначе из JWT secret)
# LICENSE_SIGNING_SECRET=

# License server (online activation / phone-home)
# LICENSE_MODE=offline | online | hybrid
# LICENSE_SERVER_URL=https://license.example.kz
# LICENSE_SERVER_ADMIN_SECRET=  # только на license server (API + support code)
# LICENSE_SERVER_LOCAL_ADMIN=   # только npm run license:admin (localhost), НЕ в docker
# PUBLIC_APP_URL=https://esedo.example.kz

# Секрет для cron/worker hooks (email-dispatch, webhook-dispatch, sla-tick, retention-tick)
# Рекомендуется в production. Заголовок: Authorization: Bearer <secret>
# CRON_SECRET=your-random-secret
# или INTERNAL_HOOK_SECRET=your-random-secret

# Опционально: отключить in-process Telegram polling (рекомендуется при >1 реплике)
# DISABLE_TELEGRAM_POLLING=true
# REPLICA_COUNT=2

# Уровень логов: debug | info | warn | error
# LOG_LEVEL=info

# TTL access JWT в минутах (refresh — HttpOnly cookie fm_refresh, см. session_ttl_hours в настройках)
# ACCESS_TOKEN_TTL_MINUTES=60

# Multi-tenant: базовый домен для поддоменов (acme.example.kz → slug acme)
# См. docs/MULTI-TENANT.md
# TENANT_BASE_DOMAIN=example.kz
# APP_BASE_DOMAIN=example.kz

# Sentry (опционально)
# SENTRY_DSN=https://key@o0.ingest.sentry.io/0
# VITE_SENTRY_DSN=https://key@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=flowmaster@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0

# UAT smoke (scripts/uat-smoke.mjs)
# APP_URL=http://127.0.0.1:3000          — app напрямую
# APP_URL=http://localhost               — через nginx (Docker)
# APP_URL=http://localhost:8080          — staging nginx
# npm run uat:smoke          — health + DB checks
# npm run uat:smoke:db       — migrations + Supabase RPC only
# npm run uat:smoke:full     — + Playwright (needs E2E_SKIP_SERVER=1 if app already running)

# E2E (Playwright) — учётная запись с правами create_documents + approve
# E2E_EMAIL=admin@example.com
# E2E_PASSWORD=your-test-password
# Cross-tenant isolation (user in org B + document UUID in org A):
# E2E_TENANT_B_EMAIL=user@tenant-b.example
# E2E_TENANT_B_PASSWORD=...
# E2E_CROSS_TENANT_DOCUMENT_ID=00000000-0000-0000-0000-000000000001
# UAT fixture (2 tenants): npm run uat:seed-fixture -- --print-env
# UAT_FIXTURE_PASSWORD=UatFixture1!
# E2E_BASE_URL=http://127.0.0.1:4173
# E2E_PORT=4173
# AUTH_RATE_LIMIT_ENABLED=false          # отключить in-memory лимиты (не рекомендуется в production)
