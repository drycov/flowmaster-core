# Production environment template for ЕСЭДО / Flowmaster Core
# Copy to .env on the server or inject via orchestrator secrets.
#
# Docker (рекомендуется on-prem):
#   node scripts/docker-setup.mjs
#   docker compose up -d --build
#   docker compose --profile cron up -d
# Полный шаблон: .env.docker.example

NODE_ENV=production
LOG_LEVEL=info

# Sentry error tracking (optional)
# SENTRY_DSN=https://key@o0.ingest.sentry.io/0
# VITE_SENTRY_DSN=https://key@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=flowmaster@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Supabase — Docker: VITE_* = http://localhost:54321, SUPABASE_URL = http://kong:8000 (в compose)
# Облако: https://your-project.supabase.co
SUPABASE_URL=http://localhost:54321
SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Installation & licensing
# INSTALLATION_ID=auto-or-explicit-uuid
# LICENSE_SIGNING_SECRET=separate-from-jwt-recommended

# Internal cron/worker authentication (required in production)
CRON_SECRET=generate-long-random-string

# Multi-replica deployment
DISABLE_TELEGRAM_POLLING=true
REPLICA_COUNT=2

# Multi-tenant (optional — wildcard subdomains acme.example.kz)
# TENANT_BASE_DOMAIN=example.kz

# Public app URL is configured in Admin → Settings → General (app_url)
# Mail, LDAP, Telegram, S3, ONLYOFFICE — Admin → Settings (stored in DB)
