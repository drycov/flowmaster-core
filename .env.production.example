# ЕСЭДО — production environment (Docker + nginx + Supabase)
# Сгенерируйте готовый файл с секретами:
#   node scripts/docker-setup-production.mjs --domain=esedo.example.kz --email=admin@example.kz
# Установить как .env:
#   node scripts/docker-setup-production.mjs --domain=esedo.example.kz --install
#
# Запуск:
#   docker compose -f docker-compose.yml -f docker-compose.nginx-tls.yml up -d --build
#   docker compose --profile cron up -d

# ── Flowmaster app ────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

APP_URL=https://esedo.example.kz
PUBLIC_APP_URL=https://esedo.example.kz

CRON_SECRET=generate-long-random-string
DISABLE_TELEGRAM_POLLING=true
REPLICA_COUNT=1

# ── Supabase API (браузер — через nginx, один домен) ─────────────────────────
VITE_SUPABASE_URL=https://esedo.example.kz
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_URL=https://esedo.example.kz
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Self-hosted Supabase (docker/supabase) ────────────────────────────────────
JWT_SECRET=your-jwt-secret
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

SECRET_KEY_BASE=generate-base64-48-bytes
VAULT_ENC_KEY=generate-32-hex-chars
PG_META_CRYPTO_KEY=generate-base64-24-bytes

LOGFLARE_PUBLIC_ACCESS_TOKEN=generate-random
LOGFLARE_PRIVATE_ACCESS_TOKEN=generate-random

S3_PROTOCOL_ACCESS_KEY_ID=generate-hex
S3_PROTOCOL_ACCESS_KEY_SECRET=generate-hex

SUPABASE_PUBLIC_URL=https://esedo.example.kz
API_EXTERNAL_URL=https://esedo.example.kz
SITE_URL=https://esedo.example.kz
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=8443

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=generate-strong-password

STUDIO_DEFAULT_ORGANIZATION=ЕСЭДО
STUDIO_DEFAULT_PROJECT=Production
PGRST_DB_SCHEMAS=public,storage,graphql_public
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
IMGPROXY_AUTO_WEBP=true
FUNCTIONS_VERIFY_JWT=false
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true
POOLER_TENANT_ID=flowmaster-prod
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DB_POOL_SIZE=5

SMTP_ADMIN_EMAIL=admin@example.kz
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_SENDER_NAME=ЕСЭДО
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

APPLY_DB_MIGRATIONS=1
APPLY_DB_SEED=0

# ── Nginx + HTTPS ─────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
PROXY_DOMAIN=esedo.example.kz
CERTBOT_EMAIL=admin@example.kz

ADDITIONAL_REDIRECT_URLS=
OPENAI_API_KEY=
SUPABASE_SECRET_KEY=

# ── Опционально ───────────────────────────────────────────────────────────────
# INSTALLATION_ID=
# LICENSE_SIGNING_SECRET=
# LICENSE_MODE=offline
# TENANT_BASE_DOMAIN=example.kz
# APP_BASE_DOMAIN=example.kz
# SENTRY_DSN=
# VITE_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=flowmaster@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.05
