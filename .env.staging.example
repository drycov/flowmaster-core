# Staging / UAT environment (copy to .env before docker compose -f docker-compose.staging.yml up)
# Or run: npm run env:staging && npm run compose:staging

NODE_ENV=production
LOG_LEVEL=debug
STAGING_PORT=3001
STAGING_NGINX_PORT=8080

# Self-hosted Supabase (npm run env:local или env:staging)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_URL=http://kong:8000
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase stack secrets (должны совпадать с SUPABASE_* выше)
JWT_SECRET=your-jwt-secret
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key
POSTGRES_PASSWORD=your-postgres-password
KONG_HTTP_PORT=54321
SUPABASE_PUBLIC_URL=http://localhost:54321
API_EXTERNAL_URL=http://localhost:54321
SITE_URL=http://localhost:8080

# Cron (required for outbox / SLA / retention in staging)
CRON_SECRET=generate-long-random-string
CRON_INTERVAL_SEC=60

# Telegram polling in cron sidecar (only if single replica and polling mode)
# ENABLE_TELEGRAM_POLL=1
DISABLE_TELEGRAM_POLLING=true

# Public URL — also set in Admin → Settings → General → app_url
# UAT через nginx:
APP_URL=http://localhost:8080
PUBLIC_APP_URL=http://localhost:8080

# E2E smoke (local or CI)
# E2E_EMAIL=uat-admin@example.kz
# E2E_PASSWORD=your-test-password
# E2E_BASE_URL=http://127.0.0.1:8080

# Optional observability
# SENTRY_DSN=
# VITE_SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging

# License (trial or FM1 key for UAT)
# LICENSE_SIGNING_SECRET=
