# Supabase (license server DB + Auth for client portal + vendor Cloud Admin)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Admin API: Bearer token for register-key, revoke, provision (machine/CI only)
LICENSE_SERVER_ADMIN_SECRET=change-me-long-random

# Cloud Admin UI (/admin): vendor staff (comma-separated emails)
LICENSE_SERVER_VENDOR_ADMIN_EMAILS=admin@example.com

# --- Vendor Telegram bot (Cloud Admin step-up only; NOT the EDMS client bot) ---
# Create via @BotFather, register webhook → /api/v1/hooks/telegram
VENDOR_TELEGRAM_BOT_TOKEN=
VENDOR_TELEGRAM_BOT_USERNAME=zeus_vendor_admin_bot
VENDOR_TELEGRAM_WEBHOOK_SECRET=random-webhook-secret
# email:telegram_chat_id (chat id from @userinfobot)
LICENSE_SERVER_VENDOR_ADMIN_TELEGRAM_CHATS=admin@example.com:123456789

# Legacy aliases (optional): TELEGRAM_BOT_TOKEN, TELEGRAM_BOT_USERNAME, TELEGRAM_WEBHOOK_SECRET

# OR approval webhook (optional; leave URL empty if only Telegram)
# Outbound notify → LICENSE_SERVER_VENDOR_ADMIN_APPROVAL_WEBHOOK_URL (internal system, not Vercel)
# Inbound approve: POST https://z-edms.vercel.app/api/v1/admin/verify/approve
#   Body: { "challenge_token": "...", "secret": "<same as below>" }
LICENSE_SERVER_VENDOR_ADMIN_APPROVAL_WEBHOOK_URL=
LICENSE_SERVER_VENDOR_ADMIN_APPROVAL_SECRET=generate-long-random-secret

# Optional
APP_VERSION=1.0.0

# --- Vite (web) — envDir: apps/cloud-license-server/; fallback SUPABASE_* if VITE_* omitted ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_LICENSE_SERVER_URL=https://your-project.vercel.app
VITE_SALES_EMAIL=
