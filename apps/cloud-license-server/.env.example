# Supabase (license server DB + Auth for client portal)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Admin API: Bearer token for register-key, revoke, provision
LICENSE_SERVER_ADMIN_SECRET=change-me-long-random

# Optional
APP_VERSION=1.0.0

# --- Vite (web) — prefix VITE_ for browser bundle ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Public URL after deploy (for cabinet setup hints)
VITE_LICENSE_SERVER_URL=https://your-project.vercel.app
# Optional — if empty, landing uses phone +7 771 051 5252
VITE_SALES_EMAIL=
