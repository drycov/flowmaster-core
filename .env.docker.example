S3_PROTOCOL_ACCESS_KEY_SECRET=850181e4652dd023b7a98c58ae0d2d34bd487ee0cc3254aed6eda37307425907

SUPABASE_PUBLIC_URL=http://localhost
API_EXTERNAL_URL=http://localhost
SITE_URL=http://localhost
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=8443

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

STUDIO_DEFAULT_ORGANIZATION=Flowmaster
STUDIO_DEFAULT_PROJECT=Local
PGRST_DB_SCHEMAS=public,storage,graphql_public
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
IMGPROXY_AUTO_WEBP=true
FUNCTIONS_VERIFY_JWT=false
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true
POOLER_TENANT_ID=flowmaster-local
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DB_POOL_SIZE=5

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

APPLY_DB_MIGRATIONS=1
APPLY_DB_SEED=1

# ── Nginx reverse proxy ───────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
STAGING_PORT=3001
STAGING_NGINX_PORT=8080
PROXY_DOMAIN=
CERTBOT_EMAIL=
SSL_SELF_SIGNED_FALLBACK=1

STUDIO_PORT=54323

# ── Мониторинг (profile monitoring) ───────────────────────────────────────────
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
MONITORING_GRAFANA_URL=http://127.0.0.1:3001
PROMETHEUS_PORT=9090
BLACKBOX_PORT=9115
CADVISOR_PORT=8081
NODE_EXPORTER_PORT=9100

ADDITIONAL_REDIRECT_URLS=
OPENAI_API_KEY=
SUPABASE_SECRET_KEY=

# Sentry (опционально)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# Multi-tenant: базовый домен для поддоменов (acme.example.kz → slug acme)
# См. docs/MULTI-TENANT.md
# TENANT_BASE_DOMAIN=example.kz

# ── Лицензирование ───────────────────────────────────────────────────────────
# Клиент (on-prem):
# LICENSE_SIGNING_SECRET=
# LICENSE_MODE=offline
# LICENSE_SERVER_URL=
#
# Vendor license server (npm run env:license-server):
# LICENSE_SERVER_ENABLED=true
# LICENSE_SERVER_ADMIN_SECRET=
