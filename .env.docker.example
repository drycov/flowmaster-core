# Flowmaster — полный Docker-стек (Supabase self-hosted + app)
# Скопируйте: node scripts/docker-setup.mjs
# Или вручную: cp .env.docker.example .env

# ── Flowmaster app ────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# Публичный URL приложения (для браузера и Vite bundle)
APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# Cron / internal hooks (обязательно в production)
CRON_SECRET=generate-long-random-string

# Telegram polling (отключить при >1 реплике app)
DISABLE_TELEGRAM_POLLING=true

# ── Supabase API (для приложения) ─────────────────────────────────────────────
# Браузер обращается к Kong на хосте:
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Сервер на хосте (npm run dev) и в Docker-контейнере app переопределяется на http://kong:8000
SUPABASE_URL=http://localhost:54321
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
