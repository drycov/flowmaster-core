# Flowmaster — шаблон Docker-стека (Supabase + app + nginx)
#
# Единственный шаблон для всех профилей. Не редактируйте вручную — генерируйте:
#   npm run env:local
#   npm run env:production -- --domain=esedo.example.kz --email=admin@example.kz
#   npm run env:staging
#   npm run env:license-server -- --domain=license.example.kz
#
# Значения по умолчанию ниже — для справки; `scripts/lib/env-profiles.mjs` подставляет
# актуальные значения при генерации (nginx URL, порты, флаги seed/migrate).
#
# ── Flowmaster app ────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# Публичный URL (через nginx — см. профиль env:local / env:production)
APP_URL=http://localhost
PUBLIC_APP_URL=http://localhost

REPLICA_COUNT=1

# Cron / internal hooks (обязательно в production)
CRON_SECRET=generate-long-random-string
# INTERNAL_HOOK_SECRET=   # альтернатива CRON_SECRET (bare-metal)

# Telegram polling (отключить при >1 реплике app)
DISABLE_TELEGRAM_POLLING=true

# ── Supabase API (для приложения) ─────────────────────────────────────────────
# Локально через nginx (после npm run env:local):
VITE_SUPABASE_URL=http://localhost
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

